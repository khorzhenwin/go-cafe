# Backend API base URL without trailing slash.
# Local browser + local backend: http://localhost:8080
# Frontend container -> backend on Docker host: http://host.docker.internal:8080
# Frontend container -> backend in another container on same Docker network: http://go-cafe-backend:8080
# Public deployed backend: https://<your-backend-domain>
API_BASE_URL=http://localhost:8080

# Optional fallback if you also call backend directly from browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
